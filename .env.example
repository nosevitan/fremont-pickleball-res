# Fremont ActiveNet credentials
ACTIVENET_USERNAME=your_username
ACTIVENET_PASSWORD=your_password

# Booking preferences
# Courts to try booking (comma-separated, in priority order)
PREFERRED_COURTS=FTC Pickleball Court A,FTC Pickleball Court B,FTC Pickleball Court C,FTC Pickleball Court D

# Time range (24h format)
BOOK_START_HOUR=16
BOOK_END_HOUR=18

# How many days ahead to book (e.g., 2 = day after tomorrow)
DAYS_AHEAD=2

# Notification (optional)
NOTIFICATION_EMAIL=
